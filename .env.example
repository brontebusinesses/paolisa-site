# PAOLISA — variables d'environnement (test / dev).
# En production (Vercel), ces variables sont définies dans le dashboard Vercel.
# Ce fichier .env.example est commit ; les vraies valeurs vont dans .env.local
# (qui est gitignored).

# Shopify — Storefront API
# Domain : "paolisa-studio.myshopify.com"
SHOPIFY_STORE_DOMAIN=
# Public Storefront access token, généré via l'app "Headless" dans Shopify.
SHOPIFY_STOREFRONT_TOKEN=

# Klaviyo — capture newsletter
KLAVIYO_API_KEY=
KLAVIYO_LIST_ID=

# Site
PUBLIC_SITE_URL=https://paolisa.eu

# Mode boutique :
#   STORE_OPEN=false → mode pré-lancement (waitlist au lieu de panier)
#   STORE_OPEN=true  → boutique ouverte, panier actif
# Au lancement, mettre "true" et redéployer.
STORE_OPEN=false
