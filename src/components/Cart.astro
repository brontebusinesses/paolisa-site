---
/**
 * <Cart /> — logique panier site-wide (rendu dans BaseLayout) :
 *  - met à jour le badge [data-cart-count] du header
 *  - intercepte les formulaires [data-add-to-cart] (ajout sans redirection)
 *  - gère l'ajout rapide [data-quick-add] depuis les cartes (sans ouvrir la fiche)
 *  - affiche un mini-panier (toast) qq secondes après l'ajout, auto-masqué 2s
 *
 * Le toast est complet sur desktop (vignette + récap sous-total + CTA paiement),
 * et volontairement compact sur mobile (vignette + « voir le panier ») pour ne
 * pas manger l'écran.
 */
---

<div
  data-cart-toast
  class="fixed z-[60] top-[92px] md:top-[104px] right-3 md:right-6 w-[calc(100%-1.5rem)] max-w-[248px] md:max-w-[350px] bg-bg-primary border border-line-subtle hidden"
  role="status"
  aria-live="polite"
>
  <div class="p-3.5 md:p-5">
    <div class="flex items-center justify-between mb-3 md:mb-4">
      <p class="mono-micro md:mono-label text-ink-primary">— AJOUTÉ AU PANIER —</p>
      <button type="button" data-cart-toast-close aria-label="Fermer" class="mono-label text-ink-tertiary hover:text-ink-primary leading-none">×</button>
    </div>
    <div class="flex gap-3 md:gap-4 items-center mb-3 md:mb-4">
      <div class="w-11 h-11 md:w-16 md:h-16 bg-bg-tertiary overflow-hidden shrink-0">
        <img data-toast-img alt="" class="w-full h-full object-cover" />
      </div>
      <div class="min-w-0">
        <p data-toast-title class="display-s truncate"></p>
        <p data-toast-meta class="body-m text-ink-tertiary text-[12px] md:text-[14px]"></p>
      </div>
    </div>

    {/* Récap + CTA paiement — desktop uniquement (compact sur mobile) */}
    <div class="hidden md:block">
      <div class="flex items-center justify-between mb-4 pt-3 border-t border-line-subtle">
        <span class="mono-label">SOUS-TOTAL</span>
        <span data-toast-subtotal class="font-mono text-[14px] tracking-[0.05em]"></span>
      </div>
      <p data-toast-nudge class="hidden body-m text-ink-secondary mb-3"></p>
      <a data-toast-checkout href="#" class="block text-center bg-bg-dark text-ink-inverse font-mono uppercase tracking-[0.14em] text-[11px] py-4 mb-2 hover:bg-ink-secondary transition-colors">
        PASSER AU PAIEMENT →
      </a>
    </div>

    <a href="/panier" class="block text-center mono-micro md:mono-label py-1 md:py-2 mt-1 md:mt-0 hover:opacity-70 transition-opacity">VOIR LE PANIER →</a>
  </div>
</div>

<script>
  import { addItem, count, subtotalCents, checkoutUrl, money, freeShipping, remainingForFree, clear, SHOP } from '../lib/cart-client';

  const updateBadge = () => {
    document.querySelectorAll<HTMLElement>('[data-cart-count]').forEach((el) => {
      el.textContent = String(count());
    });
  };
  updateBadge();
  document.addEventListener('cart:change', updateBadge);
  window.addEventListener('storage', updateBadge);

  const toast = document.querySelector<HTMLElement>('[data-cart-toast]');
  let timer: number | undefined;
  const show = (line: any) => {
    if (!toast) return;
    (toast.querySelector('[data-toast-img]') as HTMLImageElement).src = line.image;
    toast.querySelector('[data-toast-title]')!.textContent = line.title;
    toast.querySelector('[data-toast-meta]')!.textContent = `Quantité ${line.qty} · ${money(line.priceCents * line.qty)}`;
    toast.querySelector('[data-toast-subtotal]')!.textContent = money(subtotalCents());
    (toast.querySelector('[data-toast-checkout]') as HTMLAnchorElement).href = checkoutUrl();
    const nudge = toast.querySelector('[data-toast-nudge]') as HTMLElement;
    if (freeShipping()) {
      nudge.classList.add('hidden');
    } else {
      nudge.textContent = `Plus que ${money(remainingForFree())} pour la livraison offerte.`;
      nudge.classList.remove('hidden');
    }
    toast.classList.remove('hidden');
    if (timer) clearTimeout(timer);
    timer = window.setTimeout(() => toast.classList.add('hidden'), 2000);
  };
  toast?.querySelector('[data-cart-toast-close]')?.addEventListener('click', () => toast.classList.add('hidden'));

  // Formulaire d'ajout depuis la fiche produit (avec quantité).
  document.querySelectorAll<HTMLFormElement>('[data-add-to-cart]').forEach((form) => {
    form.addEventListener('submit', (e) => {
      e.preventDefault();
      const qtyInput = form.querySelector<HTMLInputElement>('[data-qty-input]');
      const qty = Math.max(1, Number(qtyInput?.value || 1));
      const line = {
        variantId: form.dataset.variant!,
        slug: form.dataset.slug!,
        title: form.dataset.title!,
        priceCents: Number(form.dataset.price),
        qty,
        image: form.dataset.image!,
        href: form.dataset.href!,
      };
      addItem(line);
      show(line);
    });
  });

  // Ajout rapide depuis une carte produit (quantité 1, sans ouvrir la fiche).
  document.querySelectorAll<HTMLButtonElement>('[data-quick-add]').forEach((btn) => {
    btn.addEventListener('click', (e) => {
      e.preventDefault();
      const line = {
        variantId: btn.dataset.variant!,
        slug: btn.dataset.slug!,
        title: btn.dataset.title!,
        priceCents: Number(btn.dataset.price),
        qty: 1,
        image: btn.dataset.image!,
        href: btn.dataset.href!,
      };
      addItem(line);
      show(line);
    });
  });

  // Quand la cliente part vers le checkout Shopify (toast ou page /panier),
  // on vide le panier local : le panier « vit » ensuite dans Shopify, et au
  // retour sur le site il repart a zero (evite le panier fantome post-commande).
  document.addEventListener('click', (e) => {
    const el = e.target as HTMLElement;
    const link = el.closest('a');
    if (!link) return;
    const href = link.getAttribute('href') || '';
    if (href.includes(SHOP + '/cart/')) {
      clear();
    }
  });

</script>
