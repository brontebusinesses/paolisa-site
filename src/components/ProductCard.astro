---
/**
 * <ProductCard /> — §5.10 (juillet 2026 : photo produit, sans code couleur).
 * Arche voûtée avec la photo du flacon, infos texte en bas. Le code couleur ne
 * vit plus que sur le packaging — les cartes montrent les vrais flacons.
 */
interface Props {
  href: string;
  image?: string | null;
  imageAlt?: string;
  eyebrow: string;     // mono label, ex. "N°01 / SÉRUM"
  title: string;
  subtitle?: string;
  price: string;
  status?: string;
}

const {
  href,
  image = null,
  imageAlt = '',
  eyebrow,
  title,
  subtitle,
  price,
  status,
} = Astro.props;
---

<a
  href={href}
  class="group block bg-bg-secondary hover:bg-bg-tertiary transition-colors duration-200 ease-in-out"
>
  {/* Arche §2.4 — photo du flacon */}
  <div class="relative w-full aspect-[3/4] overflow-hidden arch bg-bg-primary">
    {
      image ? (
        <img
          src={image}
          alt={imageAlt}
          class="absolute inset-0 w-full h-full object-cover"
          loading="lazy"
        />
      ) : (
        <div class="absolute inset-0 w-full h-full bg-line-faint flex items-center justify-center">
          <span class="mono-micro text-ink-tertiary">— PHOTO À VENIR —</span>
        </div>
      )
    }
  </div>

  {/* Infos texte */}
  <div class="px-4 md:px-6 py-6 border-t border-line-subtle">
    <p class="mono-label mb-3">{eyebrow}</p>
    <h3 class="display-s mb-1">{title}</h3>
    {subtitle && <p class="body-m text-ink-tertiary mb-4">{subtitle}</p>}
    {!subtitle && <div class="mb-4"></div>}
    <div class="flex items-baseline justify-between">
      <span class="font-mono text-ink-primary text-[14px] tracking-[0.05em]">{price}</span>
      {status && <span class="mono-micro text-ink-tertiary">{status}</span>}
    </div>
  </div>
</a>
