---
/**
 * <HeroGamme /> — hero d'accueil « composition gamme » (juillet 2026).
 * Grand titre + les 6 flacons (photos studio) en rangée d'arches, sans couleur
 * (le code couleur ne vit plus que sur le packaging). Fond crème, header opaque.
 *
 * Ajout rapide, deux formes selon l'écran :
 *   • DESKTOP : bandeau « + AJOUTER » révélé au survol, sur l'image.
 *   • MOBILE  : petit bouton rond « + » dans le coin bas-droite (zone texte),
 *     sans recouvrir la photo.
 * Géré par Cart.astro via [data-quick-add].
 */
import Button from './Button.astro';
import { productList, productLabel } from '../lib/products';
import { isStoreOpen } from '../lib/store-status';

interface Cta { label: string; href: string; }
interface Props {
  eyebrow: string;
  headlineLine1: string;
  headlineLine2?: string;
  sub?: string;
  cta1: Cta;
  cta2?: Cta;
}

const { eyebrow, headlineLine1, headlineLine2, sub, cta1, cta2 } = Astro.props;
const gamme = productList();
const storeOpen = isStoreOpen();
---

<section class="bg-bg-secondary" aria-label="Hero — la gamme">
  <div class="container-paolisa pt-8 md:pt-14">
    <p class="mono-label mb-6">{eyebrow}</p>
    <h1 class="font-sans uppercase font-medium tracking-[-0.02em] text-ink-primary leading-[0.98] text-[38px] sm:text-[48px] md:text-[60px] mb-6">
      {headlineLine1}{headlineLine2 && <><br />{headlineLine2}</>}
    </h1>
    {sub && <p class="body-l text-ink-secondary max-w-prose mb-8">{sub}</p>}
    <div class="flex flex-col sm:flex-row gap-4 sm:gap-6 mb-12 md:mb-16">
      <Button variant="primary" href={cta1.href}>{cta1.label}</Button>
      {cta2 && <Button variant="secondary" href={cta2.href}>{cta2.label}</Button>}
    </div>
  </div>

  <div class="container-paolisa">
    <ul class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-6 border-t border-line-subtle">
      {
        gamme.map((p) => (
          <li class="border-b sm:border-b-0 border-r border-line-subtle">
            {/* group + relative : les boutons d'ajout rapide s'overlayent sans
                imbriquer un <button> dans le <a> (HTML invalide). */}
            <div class="group relative">
              <a href={p.href} class="block px-3 md:px-4 pt-5 pb-6 hover:bg-bg-tertiary transition-colors duration-200 ease-in-out">
                <div class="relative w-full aspect-[3/4] overflow-hidden bg-bg-primary" style="border-radius:120px 120px 3px 3px">
                  <img src={p.cardImage} alt={p.title} class="absolute inset-0 w-full h-full object-cover" loading="lazy" />
                </div>
                <p class="mono-micro text-ink-tertiary mt-4">{p.number ? productLabel(p) : 'SOLAIRE'}</p>
                <p class="display-s mt-1">{p.title}</p>
                <p class="font-mono text-[12px] text-ink-secondary mt-2 tracking-[0.05em] pr-9 md:pr-0">{p.priceLabel}</p>
              </a>

              {
                storeOpen && p.available && (
                  <>
                    {/* DESKTOP — bandeau révélé au survol, sur l'image */}
                    <div class="hidden md:flex absolute top-5 left-4 right-4 aspect-[3/4] items-end justify-center p-2 pointer-events-none">
                      <button
                        type="button"
                        data-quick-add
                        data-variant={p.shopifyVariantId}
                        data-slug={p.slug}
                        data-title={p.title}
                        data-price={p.priceCents}
                        data-image={p.cardImage}
                        data-href={p.href}
                        class="pointer-events-auto w-full bg-bg-dark text-ink-inverse font-mono uppercase tracking-[0.1em] text-[10px] py-2 opacity-0 translate-y-2 group-hover:opacity-100 group-hover:translate-y-0 focus-visible:opacity-100 focus-visible:translate-y-0 transition-all duration-200 ease-out hover:bg-ink-secondary"
                      >
                        + AJOUTER
                      </button>
                    </div>

                    {/* MOBILE — petit bouton rond « + » dans le coin bas-droite */}
                    <button
                      type="button"
                      data-quick-add
                      data-variant={p.shopifyVariantId}
                      data-slug={p.slug}
                      data-title={p.title}
                      data-price={p.priceCents}
                      data-image={p.cardImage}
                      data-href={p.href}
                      aria-label={`Ajouter ${p.title} au panier`}
                      class="md:hidden absolute bottom-4 right-3 w-9 h-9 rounded-full bg-bg-dark text-ink-inverse flex items-center justify-center text-[18px] leading-none hover:bg-ink-secondary active:scale-95 transition"
                    >
                      +
                    </button>
                  </>
                )
              }
            </div>
          </li>
        ))
      }
    </ul>
  </div>
</section>
