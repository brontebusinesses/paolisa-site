---
/**
 * <JudgeMe /> — config + preloader Judge.me, rendu UNE fois dans BaseLayout.
 */
import { JUDGEME_SHOP_DOMAIN, JUDGEME_PUBLIC_TOKEN, JUDGEME_ENABLED } from '../lib/judgeme';
const token = JUDGEME_ENABLED ? JUDGEME_PUBLIC_TOKEN : undefined;
---

{
  token && (
    <>
      <script define:vars={{ token, shop: JUDGEME_SHOP_DOMAIN }}>
        window.jdgm = window.jdgm || {};
        window.jdgm.SHOP_DOMAIN = shop;
        window.jdgm.PLATFORM = 'shopify';
        window.jdgm.PUBLIC_TOKEN = token;
      </script>
      <script is:inline async src="https://cdn.judge.me/widget_preloader.js"></script>
    </>
  )
}
