---
/**
 * Page /merci — page de confirmation après checkout Shopify.
 *
 * Note : avec la Storefront API + Shopify Checkout hosted, après paiement
 * la cliente reste par défaut sur la page « Order status » de Shopify.
 * Cette page /merci sert :
 *   - de fallback si elle clique manuellement « Continuer » depuis Shopify,
 *   - de cible pour un éventuel script Shopify checkout (à configurer dans
 *     l'admin Shopify → Settings → Checkout → Order status page).
 *
 * Pour rediriger automatiquement les clientes ici après paiement, ajoute
 * dans Shopify : un bouton « Retour sur paolisa.eu » dans le thème de la
 * page Order status (URL → https://paolisa.eu/merci).
 */
import BaseLayout from '../layouts/BaseLayout.astro';
import NoticeBar from '../components/NoticeBar.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Button from '../components/Button.astro';
---

<BaseLayout
  title="Commande confirmée — PAOLISA"
  description="Merci. Votre commande est confirmée."
  noindex
>
  <NoticeBar message="FREE EU SHIPPING — €60+" />
  <Header transparent={false} currentPath="/merci" />

  <main>
    <section class="container-paolisa pt-12 md:pt-20 pb-20 md:pb-32">
      <div class="max-w-prose mx-auto text-center">
        <p class="mono-label mb-6">— COMMANDE CONFIRMÉE —</p>
        <h1 class="display-l mb-8">Merci.</h1>
        <p class="body-l text-ink-secondary mb-12">
          Votre paiement a bien été enregistré. Un email de confirmation
          vient de partir vers votre adresse, avec le détail de la commande
          et le numéro de suivi à l'expédition.
        </p>

        <div class="border-y border-line-subtle py-8 my-12">
          <p class="mono-label mb-4">— LA SUITE —</p>
          <p class="body-l text-ink-secondary">
            Votre flacon est préparé et expédié sous 48 heures ouvrées
            depuis Bruxelles. Vous recevrez un email avec le numéro de
            suivi dès l'expédition.
          </p>
        </div>

        <div class="flex flex-col sm:flex-row gap-4 sm:gap-6 justify-center">
          <Button variant="primary" href="/">
            RETOUR À L'ACCUEIL
          </Button>
          <Button variant="secondary" href="/journal">
            DÉCOUVRIR LE JOURNAL
          </Button>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</BaseLayout>
