---
/**
 * Origine — §4.3
 * Hero éditorial + 3 sections (PA / ISA / LISA) + manifeste long + CTA discret.
 */
import BaseLayout from '../layouts/BaseLayout.astro';
import NoticeBar from '../components/NoticeBar.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Button from '../components/Button.astro';

const chapters = [
  {
    code: 'PA',
    name: 'Paolo',
    role: 'Le Nonno',
    line: 'Italie · 1932 — 2018',
    photo: 'https://images.unsplash.com/photo-1454875392665-2ac2c85e8d3e?q=85&w=1000&h=1250&fit=crop&auto=format&fm=jpg',
    alt: 'Main posée dans une lumière douce — évocation du geste qui ne s\'oublie pas.',
    credit: 'Danie Franco / Unsplash',
    title: 'Le vélo, la fenêtre, la mémoire qui s\'efface.',
    body: [
      'Paolo réparait des vélos dans un atelier à l\'ouest de Trieste. Le geste de la main qui tourne la clé, la lumière qui passait entre deux maisons à dix heures du matin, la peau qu\'on lave à l\'huile d\'olive parce qu\'il n\'y a rien d\'autre.',
      'À la fin, il oubliait nos noms mais reconnaissait l\'odeur de l\'huile sur ses paumes. C\'est de là que vient ce flacon — d\'un geste qui ne s\'oubliait pas, même quand le reste s\'effaçait.',
    ],
  },
  {
    code: 'ISA',
    name: 'Isabelle',
    role: 'La mère',
    line: 'Bruxelles · 1968',
    photo: 'https://images.unsplash.com/photo-1560521166-117ca72366bd?q=85&w=1000&h=1250&fit=crop&auto=format&fm=jpg',
    alt: 'Goutte d\'eau claire — la fraîcheur et la simplicité d\'un soin réduit à l\'essentiel.',
    credit: 'Kelly Sikkema / Unsplash',
    title: 'Deux gestes maximum. La simplicité, c\'est aussi du soin.',
    body: [
      'Maman ne s\'est jamais maquillée. Elle se lavait le visage à l\'eau froide, mettait une huile, et c\'était tout. Quand on lui demandait son secret, elle haussait les épaules : « Il n\'y a pas de secret. »',
      'C\'est la rigueur d\'un soin réduit à son essentiel. Pas une pauvreté de moyens — un choix. Plutôt deux gestes parfaits que dix gestes approximatifs.',
    ],
  },
  {
    code: 'LISA',
    name: 'Lisa',
    role: 'La petite sœur',
    line: 'Bruxelles · 1998',
    photo: 'https://images.unsplash.com/photo-1515377905703-c4788e51af15?q=85&w=1000&h=1250&fit=crop&auto=format&fm=jpg',
    alt: 'Flacon ambré tenu dans la main — le geste de l\'huile, transmis sans un mot.',
    credit: 'Christin Hume / Unsplash',
    title: 'La passion du soin, transmise sans qu\'on s\'en aperçoive.',
    body: [
      'Lisa a grandi en regardant. Elle a appris la consistance d\'une huile entre les doigts, la lumière qu\'il faut pour bien voir sa peau, l\'heure du matin qui change tout.',
      'C\'est la transmission silencieuse. Personne n\'a enseigné, personne n\'a appris. Et pourtant tout est là.',
    ],
  },
];

const heroPhoto = {
  src: 'https://images.unsplash.com/photo-1593030019566-d681b01e877f?q=85&w=1600&h=900&fit=crop&auto=format&fm=jpg',
  alt: 'Drap de lin près d\'une fenêtre, baigné de lumière du matin.',
  credit: 'Sarah Brown / Unsplash',
};

/** Sert le WebP en priorité (le CDN Unsplash transcode via fm=webp), JPG en fallback. */
const webp = (src: string) => src.replace('fm=jpg', 'fm=webp');
---

<BaseLayout
  title="L'origine — PAOLISA"
  description="Trois prénoms. Trois générations. Une conviction. L'histoire familiale derrière Paolisa, marque-famille italo-belge de soin du visage."
>
  <NoticeBar message="EU SHIPPING · 30-DAY RETURNS" />
  <Header transparent={false} currentPath="/origine" />

  <main>
    {/* Hero éditorial */}
    <section class="section-y">
      <div class="container-paolisa text-center">
        <p class="mono-label mb-6">— L'ORIGINE —</p>
        <h1 class="display-l max-w-prose mx-auto">
          Trois prénoms.<br />Trois générations.<br />Une conviction.
        </h1>
        <figure class="mt-12 max-w-3xl mx-auto">
          <div class="relative w-full aspect-[16/9] bg-line-faint">
            <picture>
              <source srcset={webp(heroPhoto.src)} type="image/webp" />
              <img
                src={heroPhoto.src}
                alt={heroPhoto.alt}
                class="absolute inset-0 w-full h-full object-cover"
                loading="eager"
              />
            </picture>
            <div class="pointer-events-none absolute inset-0 ring-1 ring-line-faint"></div>
          </div>
        </figure>
      </div>
    </section>

    {/* Trois chapitres PA / ISA / LISA */}
    {
      chapters.map((ch, i) => (
        <section class:list={[
          'section-y',
          i % 2 === 0 ? 'bg-bg-primary' : 'bg-bg-secondary',
        ]}>
          <div class="container-paolisa">
            <div class:list={[
              'grid grid-cols-1 md:grid-cols-12 gap-8 md:gap-16 items-start',
              i === 1 ? 'md:[&>*:first-child]:order-2' : '',
            ]}>
              {/* Photo */}
              <div class="md:col-span-6">
                <figure>
                  <div class="relative w-full aspect-[4/5] bg-line-faint">
                    <picture>
                      <source srcset={webp(ch.photo)} type="image/webp" />
                      <img
                        src={ch.photo}
                        alt={ch.alt}
                        class="absolute inset-0 w-full h-full object-cover"
                        loading="lazy"
                      />
                    </picture>
                    <div class="pointer-events-none absolute inset-0 ring-1 ring-line-faint"></div>
                  </div>
                </figure>
              </div>

              {/* Texte */}
              <div class="md:col-span-6 md:pt-8">
                <p class="mono-label mb-4">— {ch.code} —</p>
                <p class="caption mb-2">{ch.name} · {ch.role}</p>
                <p class="mono-micro text-ink-tertiary mb-8">{ch.line}</p>
                <h2 class="display-m mb-8">{ch.title}</h2>
                {ch.body.map((para) => (
                  <p class="body-l text-ink-secondary mb-5 max-w-prose">{para}</p>
                ))}
              </div>
            </div>
          </div>
        </section>
      ))
    }

    {/* Manifeste long */}
    <section id="manifeste" class="bg-bg-tertiary section-y">
      <div class="container-paolisa">
        <div class="max-w-prose mx-auto text-center">
          <p class="mono-label mb-6">— MANIFESTE —</p>
          <h2 class="display-m mb-8">
            Pas de pyramide à dix étages.<br />Pas d'ingrédient miracle.<br />Pas de promesse qu'on ne tient pas.
          </h2>
          <p class="body-l text-ink-secondary mb-6">
            On a fait Paolisa parce qu'on en avait assez de l'inflation cosmétique — assez des routines à sept étapes, des sérums qui multiplient, des actifs qu'on ajoute pour faire long sur l'étiquette.
          </p>
          <p class="body-l text-ink-secondary mb-6">
            Une huile, le matin, c'est tout ce dont la peau a besoin pour démarrer la journée. Cinq végétaux purs, un aroma discret, et trente secondes de temps pour soi devant une fenêtre.
          </p>
          <p class="body-l text-ink-secondary">
            On préfère un seul produit qu'on aime à dix produits qu'on tolère.
          </p>
        </div>
      </div>
    </section>

    {/* CTA discret */}
    <section class="section-y">
      <div class="container-paolisa text-center">
        <p class="mono-label mb-4">— DÉCOUVRIR —</p>
        <h2 class="display-s mb-8">L'huile qui a donné son nom à tout ça.</h2>
        <Button variant="primary" href="/huile/no-01">
          DÉCOUVRIR L'HUILE →
        </Button>
      </div>
    </section>
  </main>

  <Footer />
</BaseLayout>
