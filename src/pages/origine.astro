---
/**
 * Origine — §4.3
 * Hero éditorial + 3 sections (PA / ISA / LISA) + manifeste long + CTA gamme.
 */
import BaseLayout from '../layouts/BaseLayout.astro';
import NoticeBar from '../components/NoticeBar.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Button from '../components/Button.astro';

const chapters = [
  {
    code: 'PAO',
    name: 'Paolo',
    role: 'Le Nonno',
    line: 'Trapani, Sicile · 1935',
    title: 'Le vélo, la fenêtre, la mémoire qui s\'efface.',
    body: [
      'Paolo, c\'est un coureur — un cycliste qui avale les longs trajets, toujours sur son vélo, du côté de Trapani, en Sicile. Une chute lui a cassé le nez, un jour, le visage presque défiguré ; il est remonté en selle. La lumière entre deux maisons à dix heures du matin, la peau qu\'on lave à l\'huile d\'olive parce qu\'il n\'y a rien d\'autre.',
      'Aujourd\'hui, il a oublié nos noms. Nous, non : on n\'oublie pas un amour qui existe, ni les moments partagés. C\'est de là que vient ce rituel — un geste qui reste, même quand le reste s\'efface.',
    ],
  },
  {
    code: 'ISA',
    name: 'Isabelle',
    role: 'La maman',
    line: 'Charleroi · 1968',
    title: 'Le juste nécessaire. La simplicité, c\'est aussi du soin.',
    body: [
      'Maman ne se maquille pas. Elle se lave le visage, met une crème hydratante — une crème toute simple, classique, la même depuis toujours — et c\'est tout.',
      'Quand on lui demande son secret, elle hausse les épaules : « Il n\'y a pas de secret. Une peau bien hydratée, voilà. » Pas une pauvreté de moyens — un choix. Plutôt quelques gestes justes que dix approximatifs.',
    ],
  },
  {
    code: 'LISA',
    name: 'Lisa',
    role: 'La petite sœur',
    line: 'Charleroi · 2003',
    title: 'La passion du soin, transmise sans qu\'on s\'en aperçoive.',
    body: [
      'Lisa a grandi en regardant — et elle a fait mieux. Elle s\'est intéressée, elle a creusé : la composition, ce qui est beau et bon pour la peau, les rituels qui tiennent vraiment.',
      'C\'est elle, surtout, qui m\'a fait comprendre l\'importance d\'une bonne routine. La transmission dans l\'autre sens : la petite sœur qui apprend tout, puis qui ouvre les yeux.',
    ],
  },
];

---

<BaseLayout
  title="L'origine — PAOLISA"
  description="Trois prénoms. Trois générations. Une conviction. L'histoire familiale derrière Paolisa, marque-famille italo-belge de soin du visage."
>
  <NoticeBar message="LIVRAISON UNION EUROPÉENNE · RETOURS SOUS 30 JOURS" />
  <Header transparent={false} currentPath="/origine" />

  <main>
    {/* Hero éditorial — ouverture typographique */}
    <section class="section-y">
      <div class="container-paolisa text-center">
        <p class="mono-label mb-6">— L'ORIGINE —</p>
        <h1 class="display-l max-w-prose mx-auto">
          Trois prénoms.<br />Trois générations.<br />Une conviction.
        </h1>
        <p class="body-l text-ink-secondary max-w-prose mx-auto mt-8">
          Paolo, Isabelle, Lisa. Une même famille, italo-belge, et un geste transmis de main en main — l'huile, le matin. PAOLISA est né de là.
        </p>
        <div class="mt-10 w-16 h-px bg-line-faint mx-auto"></div>
      </div>
    </section>

    {/* Trois chapitres PAO / ISA / LISA — texte seul */}
    {
      chapters.map((ch, i) => (
        <section class:list={[
          'section-y',
          i % 2 === 0 ? 'bg-bg-primary' : 'bg-bg-secondary',
        ]}>
          <div class="container-paolisa">
            <div class="max-w-prose mx-auto text-center">
              <p class="mono-label mb-4">— {ch.code} —</p>
              <p class="caption mb-2">{ch.name} · {ch.role}</p>
              <p class="mono-micro text-ink-tertiary mb-8">{ch.line}</p>
              <h2 class="display-m mb-8">{ch.title}</h2>
              {ch.body.map((para) => (
                <p class="body-l text-ink-secondary mb-5">{para}</p>
              ))}
            </div>
          </div>
        </section>
      ))
    }

    {/* Signature — de main en main */}
    <section class="bg-bg-secondary section-y">
      <div class="container-paolisa">
        <figure class="max-w-[180px] mx-auto">
          <div class="relative w-full aspect-[4/3] bg-line-faint">
            <picture>
              <source srcset="/origine/signature.webp" type="image/webp" />
              <img
                src="/origine/signature.jpg"
                alt="Deux mains qui se tiennent — une jeune, une âgée. Le geste transmis d'une génération à l'autre."
                class="absolute inset-0 w-full h-full object-cover"
                loading="lazy"
              />
            </picture>
            <div class="pointer-events-none absolute inset-0 ring-1 ring-line-faint"></div>
          </div>
          <figcaption class="mono-micro text-ink-tertiary text-center mt-4">— DE MAIN EN MAIN —</figcaption>
        </figure>
      </div>
    </section>

    {/* Manifeste long */}
    <section id="manifeste" class="bg-bg-tertiary section-y">
      <div class="container-paolisa">
        <div class="max-w-prose mx-auto text-center">
          <p class="mono-label mb-6">— MANIFESTE —</p>
          <h2 class="display-m mb-8">
            Pas de pyramide à dix étages.<br />Pas d'ingrédient miracle.<br />Pas de promesse qu'on ne tient pas.
          </h2>
          <p class="body-l text-ink-secondary mb-6">
            On a fait Paolisa parce qu'on en avait assez de l'inflation cosmétique — assez des routines à sept étapes, des sérums qui multiplient, des actifs qu'on ajoute pour faire long sur l'étiquette.
          </p>
          <p class="body-l text-ink-secondary mb-6">
            Un rituel court, pas une routine à rallonge. Quelques gestes choisis — un sérum, un contour, un soin (huile ou crème), une protection — dans le bon ordre, et rien de superflu.
          </p>
          <p class="body-l text-ink-secondary">
            On préfère quelques produits qu'on aime à dix qu'on tolère.
          </p>
        </div>
      </div>
    </section>

    {/* CTA — de l'huile à la gamme */}
    <section class="section-y">
      <div class="container-paolisa text-center">
        <p class="mono-label mb-6">— NOTRE PARTI PRIS —</p>
        <h2 class="display-s mb-8 max-w-prose mx-auto">Le rituel a commencé avec une huile. Il compte aujourd'hui quelques gestes choisis.</h2>
        <p class="body-l text-ink-secondary max-w-prose mx-auto mb-6">Végan, fabriqué en Europe. Des produits justes, respectueux de la peau, des animaux et de l'environnement — et assez simples pour tenir dans une vie qui va vite.</p>
        <p class="body-l text-ink-secondary max-w-prose mx-auto mb-10">Pour les femmes qui avancent, entreprennent, n'ont pas le temps, et veulent quand même prendre soin d'elles. De bons produits, sans y penser.</p>
        <div class="flex flex-col sm:flex-row gap-4 sm:gap-6 justify-center">
          <Button variant="primary" href="/gamme">
            DÉCOUVRIR LA GAMME →
          </Button>
          <Button variant="secondary" href="/huile/no-01">
            L'HUILE N°03
          </Button>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</BaseLayout>
