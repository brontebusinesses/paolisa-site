---
/**
 * PDP — N°03 Huile visage (fiche crafted, garde l'URL historique /huile/no-01)
 * Galerie photos éditoriales locales + bloc info + tabs + cross-sell.
 */
import BaseLayout from '../../layouts/BaseLayout.astro';
import NoticeBar from '../../components/NoticeBar.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import Button from '../../components/Button.astro';
import Input from '../../components/Input.astro';
import ProductGallery from '../../components/ProductGallery.astro';
import QuantitySelector from '../../components/QuantitySelector.astro';
import Accordion from '../../components/Accordion.astro';
import AvisClients from '../../components/AvisClients.astro';
import ProductCard from '../../components/ProductCard.astro';
import { getProduct, productList, productLabel } from '../../lib/products';
import { buildPdpTabs } from '../../lib/pdp-tabs';
import { isStoreOpen, LAUNCH_LABEL } from '../../lib/store-status';

const product = getProduct('no-01')!;
const storeOpen = isStoreOpen();
const label = productLabel(product);

const galleryImages = [
  { src: '/produit/no-01/1-face.jpg', alt: 'Flacon Paolisa Huile visage sur fond crème', caption: '01 — Flacon de face' },
  { src: '/produit/no-01/2-etiquette.jpg', alt: "Détail de l'étiquette", caption: '02 — Détail étiquette' },
  { src: '/produit/no-01/3-dropper.jpg', alt: 'Flacon avec dropper sorti', caption: '03 — Dropper · gouttes' },
  { src: '/produit/no-01/4-geste.jpg', alt: 'Flacon dans la main', caption: '04 — Geste · paume' },
  { src: '/produit/no-01/5-contexte.jpg', alt: 'Flacon en contexte céramique et lin', caption: '05 — Contexte' },
];

const tabs = buildPdpTabs(product);
const related = productList().filter((p) => p.slug !== 'no-01').slice(0, 3);

const avis = [
  {
    pullQuote: 'Une huile sèche. Elle prend, et la peau boit.',
    body: [
      "Je l'ai testée quelques jours. Première chose : l'odeur. Une orange douce, fraîche — rien d'entêtant. Et la couleur est belle, elle va avec le flacon.",
      "Ce qui m'a surprise, c'est la texture. Une huile sèche. Pas grasse du tout. Elle prend, et la peau boit.",
      "Le premier matin, j'ai dosé timidement — deux gouttes. Trop peu pour moi seule, j'ai remis ma crème par-dessus. Le lendemain, trois points : une joue, l'autre, le front. Là, c'était juste. Je me suis maquillée dessus, et la peau était lumineuse en dessous.",
    ],
    highlight:
      "Ce que j'aime le plus : un seul produit. Les matins pressés, c'est tout ce qu'il faut.",
    author: 'Lara',
    meta: '28 ans',
  },
];
---

<BaseLayout
  title={`${product.title} — ${product.number} · PAOLISA`}
  description={product.shortDescription}
>
  <NoticeBar message="LIVRAISON UNION EUROPÉENNE · RETOURS SOUS 30 JOURS" />
  <Header transparent={false} currentPath="/huile/no-01" />

  <main>
    <section class="container-paolisa pt-8 md:pt-12 pb-20 md:pb-32">
      <div class="grid grid-cols-1 md:grid-cols-12 gap-8 md:gap-16">
        {/* Galerie */}
        <div class="md:col-span-7">
          <ProductGallery images={galleryImages} />
        </div>

        {/* Bloc info — sticky desktop */}
        <aside class="md:col-span-5">
          <div class="md:sticky md:top-[120px] md:max-w-md">
            <p class="mono-label mb-4">{label} / {product.category}</p>
            <h1 class="display-m mb-1">{product.title}</h1>
            <p class="body-m text-ink-tertiary mb-4">{product.subtitle}</p>
            <p class="mono-label text-ink-tertiary mb-6">{product.format}</p>

            <p class="font-mono text-[18px] tracking-[0.05em] text-ink-primary mb-8">
              {product.priceLabel}
            </p>

            <p class="body-l text-ink-secondary mb-10 max-w-prose">
              {product.shortDescription}
            </p>

            {
              storeOpen ? (
                <>
                  <form
                    method="post"
                    action="https://paolisa-studio.myshopify.com/cart/add"
                    class="mb-6"
                    data-add-to-cart-form
                  >
                    <input type="hidden" name="id" value={product.shopifyVariantId} />
                    <input type="hidden" name="return_to" value="/checkout" />
                    <div class="flex flex-col sm:flex-row sm:items-center gap-4 sm:gap-6 mb-6">
                      <span class="mono-label text-ink-tertiary">QUANTITÉ</span>
                      <QuantitySelector initial={1} max={9} name="quantity" />
                    </div>
                    <Button variant="primary" type="submit" fullWidth>
                      AJOUTER AU PANIER →
                    </Button>
                  </form>

                  <p class="mono-micro text-ink-tertiary">
                    LIVRAISON UNION EUROPÉENNE &nbsp;·&nbsp; RETOURS SOUS 30 JOURS
                  </p>
                </>
              ) : (
                <div id="waitlist-block" class="border border-line-subtle p-6 md:p-8 mb-6">
                  <p class="mono-label mb-3">— BIENTÔT DISPONIBLE —</p>
                  <p class="display-s mb-4">Lancement {LAUNCH_LABEL}.</p>
                  <p class="body-l text-ink-secondary mb-8">
                    Rejoignez la liste d'attente pour recevoir l'accès en avant-première,
                    le PDF du rituel et le journal de marque.
                  </p>

                  <div data-waitlist-ok class="hidden border-t border-line-subtle pt-4 mb-6" role="status">
                    <p class="mono-label text-ink-primary mb-1">— BIEN REÇU —</p>
                    <p class="body-m text-ink-secondary">
                      Vous êtes sur la liste d'attente. Vous recevrez un email à l'ouverture des ventes.
                    </p>
                  </div>
                  <div data-waitlist-erreur class="hidden border-t border-line-subtle pt-4 mb-6" role="alert">
                    <p class="mono-label text-ink-primary mb-1">— ERREUR —</p>
                    <p class="body-m text-ink-secondary">
                      Vérifiez votre adresse email et réessayez.
                    </p>
                  </div>

                  <form method="post" action="/api/newsletter" class="space-y-6" data-waitlist-form>
                    <input type="hidden" name="source" value="waitlist" />
                    <input type="hidden" name="return" value="/huile/no-01" />
                    <div>
                      <label class="sr-only" for="waitlist-email">Votre email</label>
                      <Input
                        type="email"
                        name="email"
                        id="waitlist-email"
                        placeholder="VOTRE EMAIL"
                        required
                        ariaLabel="Votre adresse email"
                        autocomplete="email"
                      />
                    </div>
                    <Button variant="primary" type="submit" fullWidth>
                      REJOINDRE LA LISTE D'ATTENTE →
                    </Button>
                  </form>

                  <p class="mono-micro text-ink-tertiary mt-6">
                    DÉSINSCRIPTION EN UN CLIC. PAS DE SPAM, JAMAIS.
                  </p>
                </div>

                <script is:inline>
                  (function () {
                    const params = new URLSearchParams(window.location.search);
                    const status = params.get('newsletter');
                    if (status !== 'ok' && status !== 'erreur') return;

                    const ok = document.querySelector('[data-waitlist-ok]');
                    const erreur = document.querySelector('[data-waitlist-erreur]');
                    if (status === 'ok') {
                      ok && ok.classList.remove('hidden');
                      const form = document.querySelector('[data-waitlist-form]');
                      form && form.classList.add('hidden');
                    } else {
                      erreur && erreur.classList.remove('hidden');
                    }

                    const block = document.getElementById('waitlist-block');
                    block && block.scrollIntoView({ behavior: 'smooth', block: 'center' });

                    const cleanUrl = window.location.pathname + window.location.hash;
                    window.history.replaceState({}, document.title, cleanUrl);
                  })();
                </script>
              )
            }
          </div>
        </aside>
      </div>

      {/* Onglets */}
      <div class="mt-20 md:mt-32 grid grid-cols-1 md:grid-cols-12 gap-8 md:gap-16">
        <div class="md:col-span-4">
          <h2 class="display-s mb-3">— LE PRODUIT EN DÉTAIL</h2>
          <p class="mono-label">{label} / {product.category}</p>
        </div>
        <div class="md:col-span-8">
          <Accordion items={tabs} variant="default" />
        </div>
      </div>
    </section>

    {/* Avis clientes */}
    <AvisClients
      eyebrow="— AVIS —"
      title="Premiers retours."
      subEyebrow="N°03 HUILE / TESTEUSE"
      reviews={avis}
      background="tertiary"
    />

    {/* Compléter le rituel */}
    <section class="bg-bg-secondary section-y">
      <div class="container-paolisa">
        <div class="flex items-center gap-4 mb-8">
          <p class="mono-label whitespace-nowrap text-ink-primary">— COMPLÉTER LE RITUEL</p>
          <span class="flex-1 border-t border-line-subtle"></span>
          <a href="/gamme" class="mono-label whitespace-nowrap hover:opacity-70">TOUTE LA GAMME →</a>
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-3 gap-px bg-line-faint border border-line-faint">
          {
            related.map((p) => (
              <ProductCard
                href={p.href}
                image={p.images[0]}
                imageAlt={p.title}
                eyebrow={`${productLabel(p)} / ${p.category}`}
                title={p.title}
                subtitle={p.subtitle}
                price={p.priceLabel}
                status={p.status}
              />
            ))
          }
        </div>
      </div>
    </section>
  </main>

  <Footer />
</BaseLayout>
